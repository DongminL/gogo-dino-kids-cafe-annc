{
  "name": "gogo-dino-annc",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "vite build && electron-builder --win",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "build": {
    "appId": "com.gogodino.annc",
    "productName": "고고 다이노 안내 방송",
    "files": [
      "build/**/*",
      "!build/**/*.map",
      "public/electron.js",
      "public/logo.png"
    ],
    "compression": "maximum",
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.98.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "lucide-react": "^0.577.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4"
  }
}
